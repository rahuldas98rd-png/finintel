# LLM provider
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GROQ_API_KEY=gsk_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
HF_TOKEN=hf_XXXXXXXXXXXXXXXXXXXXXXXXX

LLM_MODEL=llama-3.1-8b-instant

# SEC EDGAR requires a User-Agent string with a real email (their ToS)
SEC_USER_AGENT="Rahul Das test@test.com"

# Qdrant connection
# Local development (default): leave QDRANT_URL pointed at the Docker container,
# leave QDRANT_API_KEY blank.
# Production / HF Spaces: point QDRANT_URL at your Qdrant Cloud cluster
# and set QDRANT_API_KEY to the cloud API key.
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
